#!/usr/bin/env bash
set -euo pipefail

choice=$(printf "蟀惀 Shutdown\n蟀湁 Reboot\n蟀挷 Suspend\n髰瘝 Logout\n蟀尵 Lock" | walker --dmenu --placeholder "Power" 2>/dev/null)

case "$choice" in
    *Shutdown) systemctl poweroff ;;
    *Reboot)   systemctl reboot ;;
    *Suspend)  systemctl suspend ;;
    *Logout)   hyprctl dispatch exit ;;
    *Lock)     "$HOME/.config/hypr/start-hyprlock" ;;
esac
