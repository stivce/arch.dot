#!/usr/bin/env bash
# set-wallpaper — pick a wallpaper via wofi and apply matugen color scheme
set -euo pipefail

WALLPAPER_DIR="$HOME/Pictures/wallpapers"

mapfile -t wallpapers < <(find "$WALLPAPER_DIR" -maxdepth 1 -type f \
    \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' \) \
    | sort)

names=()
for w in "${wallpapers[@]}"; do
    names+=("$(basename "$w")")
done

selected=$(printf '%s\n' "${names[@]}" | wofi --dmenu --prompt "Wallpaper")
[[ -z "$selected" ]] && exit 0

WALLPAPER="$WALLPAPER_DIR/$selected"

echo "Setting wallpaper: $selected"
awww img "$WALLPAPER"

echo "Generating color scheme with matugen..."
matugen image "$WALLPAPER" --source-color-index 0

if pgrep -x kitty &>/dev/null; then
    pkill -USR1 kitty
fi

if pgrep -x waybar &>/dev/null; then
    pkill -SIGUSR2 waybar
fi

echo "Done."
