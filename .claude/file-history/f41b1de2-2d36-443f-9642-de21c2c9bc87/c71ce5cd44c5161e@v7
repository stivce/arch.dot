* {
    font-family: "JetBrainsMono Nerd Font";
    font-size: 14px;
}

window {
    background-color: transparent;
}

entry, #input {
    background-color: #1e1f25;
    color: #e2e2e9;
    border: none;
    border-bottom: 1px solid #45464f;
    border-radius: 10px 10px 0 0;
    padding: 12px 16px;
    margin: 0;
    box-shadow: none;
    outline: none;
    caret-color: #e2e2e9;
}

entry:focus, #input:focus {
    outline: none;
    background-color: #1e1f25;
    box-shadow: none;
    border-bottom: 1px solid #b2c5ff;
}

#inner-box {
    background-color: transparent;
}

#outer-box {
    background-color: alpha(#121318, 0.35);
    border: 1px solid alpha(#45464f, 0.27);
    border-radius: 10px;
    padding: 8px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
}

#scroll {
    background-color: transparent;
}

#text {
    color: #e2e2e9;
    padding: 2px 8px;
}

#entry {
    padding: 6px 8px;
    border-radius: 6px;
}

#entry:selected {
    background-color: #282a2f;
}

#entry:selected #text {
    color: #e2e2e9;
}
