* {
    font-family: "JetBrainsMono Nerd Font";
    font-size: 14px;
}

window {
    background-color: alpha({{colors.surface.dark.hex}}, 0.3);
    border-radius: 10px;
}

entry, #input {
    background-color: alpha({{colors.surface_container.dark.hex}}, 0.5);
    color: {{colors.on_surface.dark.hex}};
    border: none;
    border-radius: 0;
    padding: 12px 16px;
    margin: 0;
    box-shadow: none;
    outline: none;
    caret-color: {{colors.on_surface.dark.hex}};
}

entry:focus, #input:focus {
    outline: none;
    background-color: alpha({{colors.surface_container.dark.hex}}, 0.5);
    box-shadow: none;
    border-bottom: 1px solid {{colors.primary.dark.hex}};
}

#inner-box {
    background-color: transparent;
    border-radius: 10px;
}

#outer-box {
    background-color: alpha({{colors.surface.dark.hex}}, 0.35);
    border: 1px solid alpha({{colors.outline_variant.dark.hex}}, 0.27);
    border-radius: 10px;
    padding: 8px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
}

#scroll {
    background-color: transparent;
}

#text {
    color: {{colors.on_surface.dark.hex}};
    padding: 2px 8px;
}

#entry {
    padding: 6px 8px;
    border-radius: 6px;
}

#entry:selected {
    background-color: {{colors.surface_container_high.dark.hex}};
}

#entry:selected #text {
    color: {{colors.on_surface.dark.hex}};
}
