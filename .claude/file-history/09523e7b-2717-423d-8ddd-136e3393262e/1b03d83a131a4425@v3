/* Generated by matugen — do not edit manually */
* {
    font-family: "Inter Variable", "Inter", sans-serif;
    font-size: 18px;
    color: {{colors.on_surface.dark.hex}};
    min-height: 0;
    border: none;
    border-radius: 0;
}

window#waybar {
    background-color: alpha({{colors.surface.dark.hex}}, 0.3);
    border-bottom: 1px solid alpha({{colors.outline_variant.dark.hex}}, 0.3);
}

#workspaces button {
    color: {{colors.on_surface_variant.dark.hex}};
    padding: 0 8px;
    background: transparent;
}

#workspaces button.active {
    color: {{colors.primary.dark.hex}};
}

#workspaces button:hover {
    background: alpha({{colors.primary.dark.hex}}, 0.1);
}

#window {
    color: {{colors.on_surface_variant.dark.hex}};
}

#clock,
#custom-packages,
#custom-disk-root,
#custom-disk-home {
    color: {{colors.on_surface.dark.hex}};
    padding: 0 8px;
}

#custom-packages {
    color: {{colors.tertiary.dark.hex}};
}
